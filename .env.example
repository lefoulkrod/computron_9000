# Example environment variables for computron_9000

# LLM host override for Ollama AsyncClient
# Leave empty to use library defaults.
LLM_HOST=

# Anthropic API key (required when llm.provider is "anthropic")
# Get yours at: https://console.anthropic.com
LLM_API_KEY=

# Reddit API credentials (optional)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=

# IF using the Google search API, set your API key here
GOOGLE_SEARCH_API_KEY=
# If you are using a Programmable Search Engine, add its ID here
GOOGLE_SEARCH_ENGINE_ID=

# HuggingFace token (for gated models like Flux.1-schnell)
HF_TOKEN=

# GitHub personal access token (for publishing repos and GitHub Pages)
# Create a fine-grained token at: https://github.com/settings/tokens?type=beta
# Required permissions: Contents (read/write), Pages (read/write), Metadata (read)
GITHUB_TOKEN=
GITHUB_USER=